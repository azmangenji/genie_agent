TILEBUILDERCHECKLOGS_IGNORE_PATTERN_GenericFmEqv += /Error : Formality max mem usage .* MB exceed expectation of .*/
TILEBUILDERCHECKLOGS_IGNORE_PATTERN_FxFpPreSynPlaceMacros += /.*tCIC_.*/
