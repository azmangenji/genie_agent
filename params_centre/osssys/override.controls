TILEBUILDERCHECKLOGS_IGNORE_PATTERN += /ATTENTION: Runtime impact. Formality was unable to take full advantage of all/
TILEBUILDERCHECKLOGS_IGNORE_PATTERN += /Error.*Formality run time.*seconds exceed.*seconds./
TILEBUILDERCHECKLOGS_IGNORE_PATTERN += /Error.*Formality max mem usage.*exceed.*expectation of.*MB./
TILEBUILDERCHECKLOGS_IGNORE_PATTERN += /Error.*Please file a jira on CAD in respective family if the difference between expected and actual value is very high/

# FE Specific Cleanup Controls
ACTION_pretiming_SKIP = 0
ACTION_power_SKIP = <:
    $ACTION_power_SKIP = 1;
    if ((defined $STACK_SAIF_OPT_FxSynthesize) and ($STACK_SAIF_OPT_FxSynthesize =~ /\w/)) {
        $ACTION_power_SKIP = 0;
    }
    print $ACTION_power_SKIP;
:>
ACTION_prc_SKIP = <:
    $ACTION_prc_SKIP = 1;
    if ($DFP_SRC_PRESYN_UPF_BYCOPY =~ /\w/) {
        $ACTION_prc_SKIP = 0;
    }
    print $ACTION_prc_SKIP;
:>
ACTION_apply_eco_SKIP = 1
ACTION_checks_SKIP = 1
ACTION_classify_SKIP = 1
ACTION_dfm_SKIP = 1
ACTION_domain_crossing_SKIP = 1
ACTION_guidelines_analysis_SKIP = 1
ACTION_ilm_SKIP = 1
ACTION_lh_SKIP = 1
ACTION_route_timing_SKIP = 1
ACTION_signalem_SKIP = 1
ACTION_sort_timing_SKIP = 1
ACTION_vtswap_SKIP = 1

#Force enable actions for fin fet checks
<:print "ACTION_design_checks_SKIP = 0";:>
<:print "ACTION_fin_fet_count_SKIP = 0";:>

# Cleanup extra PtGen targets when running only FE portion.
<:
    if ($GEN_SDC_READ_SYNTHESIZE_SDC == "1") {
        foreach $mode (split /\s+/, $RELEASED_SDC_MODE_LIST) {
            if ($OPTIMIZATION_MMMC_MODE_LIST_FxSynthesize !~ /\b$mode\b/) {
                print "TARGET_REMOVE_PtGenSdc${mode}${OPTIMIZATION_SETUP_LIB}PostDftStp = 1\n";
                print "TARGET_REMOVE_PtGenSdc${mode}${OPTIMIZATION_SETUP_LIB}SynthesizeStp = 1\n";            
            }
        }
    }
:>

# Cleanup extra Vsi targets.
<:
    foreach $stage (split /\s+/, $LP_PHYS_CHK_LIST) {
        if ($STACK_RUN_MERGE_FLOW_SKIPPING_PNR_TARGETS == "1") {
            if ($stage =~ /Rtl/ && ($STACK_IS_POWER_GATING == "1" || $STACK_IS_MULTI_VOLTAGE == "1" || $STACK_IS_AON_VSI == "1")) {
                next;
            } elsif ($stage =~ /Synthesize/ && ($STACK_IS_POWER_GATING == "1" || $STACK_IS_MULTI_VOLTAGE == "1" || $STACK_IS_AON_VSI == "1")) {
                next;
            } elsif ($stage =~ /PrePlace/ && ($STACK_IS_POWER_GATING == "1" || $STACK_IS_MULTI_VOLTAGE == "1" || $STACK_IS_AON_VSI == "1")) {
                next;
            } else {
                print "TARGET_REMOVE_Vsi${stage}PRC = 1\n";
                print "TARGET_REMOVE_ApplyVsiWaiver${stage}PRC = 1\n";                
            }
        }
    }
:>

