<:
    # Switch for different DED types.
    $FEINT_DED_TYPE = 2;

    %ded = ();
    $ded{'1'}{'proj'} = "df-ver";
    $ded{'1'}{'sel'} = "soc_aidd||jesko";
    $ded{'2'}{'proj'} = "mi400-pd";
    $ded{'2'}{'sel'} = "jesko||soc_aidd";

    if ($FEINT_DED_MACHINE_TILES_LIST =~ /\b$TOP_MODULE\b/ && `whoami | tr -d "\\n"` =~ /ericlam2|jonguyen|kamkanel|kdu|kilee/) {
        foreach $target ("FxFpPreSynPlaceMacros", "FxFpPreSynInsertPhysicalCells", "FxFpPreSynGenInternalPowerGrid", "FxFpPreSynFinishPower", "FxPreSynFloorPlan", "FxSynthesize", "FxPrePlace") {
        #foreach $target ("FxFpPreSynPlaceMacros", "FxFpPreSynInsertPhysicalCells", "FxFpPreSynGenInternalPowerGrid", "FxFpPreSynFinishPower", "FxPreSynFloorPlan", "FxPrePlace") {
            print "TILEBUILDER_LSFPROJECT_$target = $ded{$FEINT_DED_TYPE}{'proj'}\n";
            print "TILEBUILDER_LSFSELECT_$target = $ded{$FEINT_DED_TYPE}{'sel'}\n";
            print "TILEBUILDER_LSFQUEUE_$target = ded\n";
            print "TILEBUILDER_CPUS_$target = 32\n";
            print "TILEBUILDER_EXECARCH_$target = rhel7or8\n";

        }
    }
:>

