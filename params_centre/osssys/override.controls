<:
# Gather all inputs from release area for Fast Mode Synthesis.
if ($SYN_ECO_FAST_MODE) {
    print "TARGET_REMOVE_FmEqvSynRtlVsFCFPSynRtl = 1\n";
    print "TARGET_REMOVE_FxFpPreSynFinishPower = 1\n";
    print "TARGET_REMOVE_FxFpPreSynGenInternalPowerGrid = 1\n";
    print "TARGET_REMOVE_FxFpPreSynInsertPhysicalCells = 1\n";
    print "TARGET_REMOVE_FxFpPreSynPlaceMacros = 1\n";
    print "TARGET_REMOVE_FxGenTileBBox = 1\n";
    print "TARGET_REMOVE_FxGenTileNetlist = 1\n";
    print "TARGET_REMOVE_FxPreSynFloorPlan = 1\n";
    print "TARGET_REMOVE_GenericPlFcGenClkSdc = 1\n";
    print "TARGET_REMOVE_GetSdc = 1\n";
    print "TARGET_REMOVE_PlGenRepeaterRtl = 1\n";
    print "TARGET_REMOVE_PyMapLcSynRtlVsGetRtl = 1\n";
    print "TARGET_REMOVE_PyMapLcSynthesizeVsSynRtl = 1\n";
    print "TARGET_REMOVE_PyOaInsertFcfpFeedsReps = 1\n";
    print "TARGET_REMOVE_ShGetDef = 1\n";
    print "TARGET_REMOVE_ShGetFcFpFeedthroughData = 1\n";
    print "TARGET_REMOVE_ShGetFcfpParams = 1\n";

    print "INPUT_SYN_RTL = data/GetRTL/GetRTL.vf\n";

    # Add User Code to copy TOP_MODULE.rep.v and other files
    #ECO_FUNC_PREECO_PATH = /proj/cmb_release_vol1/a0/VCN_HCF/NLDp3_last/tiles/$TOP_MODULE/latest

    @files = (
        "data/SynRtl/${TOP_MODULE}.rep.v",
        "data/SynRtl/gate_level_stac_repeater_${TOP_MODULE}.v",
        'data/GenTileBBox.macros.json.gz', #
        'data/FpInsertPhysicalCells.routing_guides.tcl',
        'data/PlFcGenFULLCHIPTIMING*ClkSdc.clock.falsepaths.sdc.gz',
        'data/PlFcGenFULLCHIPTIMING*ClkSdc.clock.sdc.gz',
        'data/PreSynFloorPlan.boundbufs.json.gz',
        'data/PreSynFloorPlan.dfpParams', #
        'data/PreSynFloorPlan.def.gz',
        'data/PreSynFloorPlan.metalFillOnlyRBlkg.tcl',
        'data/io_false_group.tcl', #
    );

    $vov_cmd = "";
    $vov_out = "";

    if (-e "${ECO_FUNC_PREECO_PATH}/bom.json") {
        foreach $file (@files) {
            $rel_files = `ls ${ECO_FUNC_PREECO_PATH}/$file`;
            if ($rel_files =~ /\w/) {
                foreach $rel_file (split (/\s/, $rel_files)) {
                    # Strip Full Path
                    $data_file = $rel_file;
                    $data_file =~ s/${ECO_FUNC_PREECO_PATH}//;
                    $data_file =~ s/^\///;
                    $vov_cmd .= "rm -rf $data_file ; cp -rfvL $rel_file $data_file ; md5sum $rel_file $data_file ; ";
                    $vov_out .= "$data_file ";
                }
            }
        }
    
        if (-e "${ECO_FUNC_PREECO_PATH}/data/SynRtl/${TOP_MODULE}.rep.v") {
            $vov_cmd .= "sed -ie \"s/data\\/SynRtl\\/${TOP_MODULE}\\.v/data\\/SynRtl\\/${TOP_MODULE}.rep.v/ig\" data/SynRtl/SynRtl.vf ; ";
        }
        if (-e "${ECO_FUNC_PREECO_PATH}/data/SynRtl/gate_level_stac_repeater_${TOP_MODULE}.v") {
            $vov_cmd .= "echo data/SynRtl/gate_level_stac_repeater_${TOP_MODULE}.v >> data/SynRtl/SynRtl.vf ; ";
        }
    }

    print "TARGET_FINISH_USERCODE_ShSynRtl = $vov_cmd\n";
    print "TARGET_USERVOVOUTPUTS_ShSynRtl = $vov_out\n";
}
:>

