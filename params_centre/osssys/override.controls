# Auto ER
SET_ER_RUNDIR_CMD = <:
    $SET_ER_RUNDIR_CMD = "";
    %er_map = ( sawatchrange => 'SawatchRange.er',
                cumberland => 'cumberland.er' );

    if ($TOP_MODULE =~ /$ER_TILES_NAME_REGEX/) {
        $SET_ER_RUNDIR_CMD = "/bin/whoami; /bin/chgrp $er_map{$PROJECT} ${BASE_DIR}; /bin/chmod 770 ${BASE_DIR};";
    }

    print $SET_ER_RUNDIR_CMD;
:>

