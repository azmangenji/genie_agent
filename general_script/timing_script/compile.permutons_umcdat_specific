# ============================================================================
# UMCDAT-SPECIFIC PERMUTONS
# Target: Security/Encryption Timing Issues
# Focus: AES pipelines, XTS transformation, key expansion, ECC logic
# ============================================================================
#
# Problem Analysis:
#   - UMCSEC encryption pipelines: 3,095 failing paths (119% of total!)
#   - RdKeyPipe: 274 paths, WrKeyPipe: 170 paths (key expansion)
#   - XtsDatPipe: 426 paths (XTS data transformation)
#   - ECCRD: 354 paths (ECC read logic)
#   - Aes128Mode_reg: 122 critical startpoint paths (4.7%)
#   - Deep pipelines: 22-35 levels of logic
# ============================================================================

# ✅ KEPT: Permuton 1 - AES Pipeline Stage Balancing
# Impact: 119% of failures (3,095 paths - MASSIVE! Paths counted across multiple stages)
# Reason: BIGGEST bottleneck by far, targets main encryption pipeline
create_permuton \
  -name umcdat_aes_pipeline_balance \
  -description {Balance AES encryption pipeline stages to distribute logic evenly and reduce critical path depth} \
  -stages {compile} \
  -focus fusion \
  -target timing \
  -type custom \
  -range {none light balanced aggressive} \
  -datatype categorical \
  -procedure_file /proj/rtg_oss_er_feint2/abinbaba/ROSENHORN_DSO_v2/main/pd/tiles/dso_timing_enhancement/procs/umcdat_aes_pipeline_procs.tcl \
  -before_proc {::DSO::PERMUTONS::umcdat_before_aes_pipeline_proc umcdat_aes_pipeline_balance} \
  -after_proc ::DSO::PERMUTONS::umcdat_after_aes_pipeline_proc \
  -checkpoints {compile*final_opto*}

# ✅ KEPT: Permuton 2 - Key Expansion Pipeline Retiming
# Impact: 17.1% of failures (444 paths: RdKeyPipe 274 + WrKeyPipe 170)
# Reason: SECOND HIGHEST impact, specific key expansion bottleneck
create_permuton \
  -name umcdat_key_pipeline_retime \
  -description {Retime key expansion pipelines (RdKeyPipe, WrKeyPipe) to move registers for optimal timing} \
  -stages {compile} \
  -focus fusion \
  -target timing \
  -type custom \
  -range {none forward backward adaptive} \
  -datatype categorical \
  -procedure_file /proj/rtg_oss_er_feint2/abinbaba/ROSENHORN_DSO_v2/main/pd/tiles/dso_timing_enhancement/procs/umcdat_key_retime_procs.tcl \
  -before_proc {::DSO::PERMUTONS::umcdat_before_key_retime_proc umcdat_key_pipeline_retime} \
  -after_proc ::DSO::PERMUTONS::umcdat_after_key_retime_proc \
  -checkpoints {compile*final_opto*}

