# ✅ KEPT: Path margin adjustment for timing pressure
# Impact: Tightens timing margins to force tool to work harder on critical paths
create_permuton \
  -name dso_scale_margins \
  -description {Adjust pre-existing global/customized path margins by a percentage of a main clock. Reverts back after checkpoint.} \
  -type custom \
  -range {-1 0} \
  -datatype discrete \
  -procedure_file $::env(FLOW_DIR)/supra/templates/dso_shell/dso_permutons/power_timing/procs/compile/dso_scale_margins_procs.tcl \
  -before_proc {dso_scale_setup_path_margins_global {dso_scale_margins main_clock}} \
  -after_proc dso_reset_setup_path_margins_global \
  -checkpoints {*_opt*} \
  -arg_values {main_clock USE_FASTEST_CLOCK}

