create_permuton \
  -name dso_enable_ALR \
  -description {Permute options to enable advanced logic restructuring modes.  } \
  -stages {compile} \
  -focus general \
  -target timing \
  -type custom \
  -range {area_timing timing_power} \
  -datatype categorical \
  -procedure_file $::env(FLOW_DIR)/supra/templates/dso_shell/dso_permutons/power_timing/procs/compile/dso_enable_ALR_procs.tcl \
  -before_proc {dso_before_ALR_alt dso_enable_ALR cost} \
  -after_proc dso_after_ALR \
  -checkpoints {compile*final_opto* place*final_opto* clock*} \
  -arg_values {cost medium}

create_permuton \
  -name dso_scale_margins \
  -description {Adjust pre-existing global/customized path margins by a percentage of a main clock. Reverts back after checkpoint.} \
  -type custom \
  -range {-1 0} \
  -datatype discrete \
  -procedure_file $::env(FLOW_DIR)/supra/templates/dso_shell/dso_permutons/power_timing/procs/compile/dso_scale_margins_procs.tcl \
  -before_proc {dso_scale_setup_path_margins_global {dso_scale_margins main_clock}} \
  -after_proc dso_reset_setup_path_margins_global \
  -checkpoints {*_opt*} \
  -arg_values {main_clock USE_FASTEST_CLOCK}

