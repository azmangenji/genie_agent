# ✅ KEPT: Permuton 1 - High-Fanout Register Duplication
# Impact: 32.2% of all failures (1,158 paths: MrDimmEn 665 + AutoRefReqPlr 309 + IdleBWCfg 184)
# Reason: BIGGEST single bottleneck, proven register duplication technique
# V2 CHANGE: checkpoint compile*final_opto* -> compile_logic_opto (structural change, early stage)
create_permuton \
  -name umccmd_fanout_duplication \
  -description {Duplicate high-fanout control registers (MrDimmEn, AutoRefReqPlr, IdleBWCfg) to reduce fanout and improve timing} \
  -stages {compile} \
  -focus fusion \
  -target timing \
  -type custom \
  -range {none low medium high} \
  -datatype categorical \
  -procedure_file /proj/rtg_oss_er_feint2/abinbaba/ROSENHORN_DSO_v2/main/pd/tiles/dso_timing_enhancement/procs/umccmd_fanout_duplication_procs.tcl \
  -before_proc {::DSO::PERMUTONS::umccmd_before_fanout_dup_proc umccmd_fanout_duplication} \
  -after_proc ::DSO::PERMUTONS::umccmd_after_fanout_dup_proc \
  -checkpoints {compile_logic_opto}

