# ✅ NEW Permuton 13 - Clock Gate Path Group
# From v5 TCL: group_path -name umc_clkgate_r2r -weight 6 -range 400
# clock_gating_default: NVP=545, TNS=-10,175ps, WNS=-59ps
# NEVER targeted in any DSO lineage across 28Jan40p or 4Mac40p runs
# Explores optimal weight without stealing resources from ARB/DCQARB groups
