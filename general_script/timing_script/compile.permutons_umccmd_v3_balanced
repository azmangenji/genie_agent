  -checkpoints {compile*}

# ✅ NEW Permuton 14 - DCQARB Max Fanout
# From v5 TCL: set_max_fanout 30 $dcqarb_cells
# DCQARB contains 49.8% of all registers - high-fanout control nets slow R2R paths
# Explores optimal limit: too tight=excessive buffering, too loose=slow nets remain
create_permuton \
  -name umccmd_dcqarb_max_fanout \
  -description {DCQARB max fanout: none=tool default, 20=aggressive, 30=v5 TCL, 40=moderate} \
  -stages {compile place} \
  -focus fusion \
  -target timing \
  -type custom \
  -range {none 20 30 40} \
  -datatype categorical \
  -procedure_file /proj/rtg_oss_er_feint2/abinbaba/ROSENHORN_DSO_v2/main/pd/tiles/dso_timing_enhancement/procs/umccmd_dcqarb_fanout_procs.tcl \
